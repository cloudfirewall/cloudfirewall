{
  "policyId": "policy-public-web",
  "versionNumber": 1,
  "environmentId": "env-public-web",
  "name": "public-web-server",
  "description": "Allow HTTPS publicly and SSH only from office",
  "defaultInboundAction": "DENY",
  "defaultOutboundAction": "ALLOW",
  "systemRules": {
    "allowLoopback": true,
    "allowEstablishedRelated": true
  },
  "rules": [
    {
      "id": "rule-https",
      "direction": "INBOUND",
      "action": "ALLOW",
      "source": {
        "type": "PSEUDO",
        "pseudoType": "PUBLIC_INTERNET"
      },
      "destination": {
        "type": "PSEUDO",
        "pseudoType": "THIS_NODE"
      },
      "service": {
        "type": "LITERAL",
        "protocol": "TCP",
        "ports": [
          443
        ]
      },
      "logEnabled": false,
      "enabled": true,
      "orderIndex": 10,
      "description": "Allow public HTTPS"
    },
    {
      "id": "rule-ssh",
      "direction": "INBOUND",
      "action": "ALLOW",
      "source": {
        "type": "OBJECT",
        "objectName": "office-ips"
      },
      "destination": {
        "type": "PSEUDO",
        "pseudoType": "THIS_NODE"
      },
      "service": {
        "type": "LITERAL",
        "protocol": "TCP",
        "ports": [
          22
        ]
      },
      "logEnabled": true,
      "enabled": true,
      "orderIndex": 20,
      "description": "Allow SSH from office"
    }
  ]
}
