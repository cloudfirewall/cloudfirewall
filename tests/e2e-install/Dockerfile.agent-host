FROM alpine:3.20

RUN apk add --no-cache ca-certificates curl tar nftables netcat-openbsd

WORKDIR /workspace

COPY tests/e2e-install/agent-host-entrypoint.sh /usr/local/bin/agent-host-entrypoint.sh
RUN chmod +x /usr/local/bin/agent-host-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/agent-host-entrypoint.sh"]
