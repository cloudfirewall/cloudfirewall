FROM golang:1.23.2-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/api ./apps/api/cmd/api

FROM alpine:3.20
RUN apk add --no-cache ca-certificates wget
WORKDIR /app
COPY --from=builder /out/api /usr/local/bin/api
COPY apps/engine/testdata/compiled/public-web-server.nft.golden /app/public-web-server.nft
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/api", "-addr", ":8080", "-config", "/app/public-web-server.nft"]
