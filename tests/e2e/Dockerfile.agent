FROM golang:1.23.2-alpine AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/agent ./apps/agent/cmd/agent

FROM alpine:3.20
RUN apk add --no-cache ca-certificates nftables netcat-openbsd
COPY --from=builder /out/agent /usr/local/bin/agent
COPY tests/e2e/agent-entrypoint.sh /usr/local/bin/agent-entrypoint.sh
RUN chmod +x /usr/local/bin/agent-entrypoint.sh
ENTRYPOINT ["/usr/local/bin/agent-entrypoint.sh"]
